    "test:contradiction": "tsx test/axiom-os-contradiction-detector-test.ts",
    "test:theory-evolution": "tsx test/axiom-os-theory-evolution-test.ts",
    "test:seed-transfer": "tsx test/axiom-os-seed-transfer-test.ts",
    "test:explainability": "tsx test/axiom-os-explainability-test.ts",
    "test:temporal-reasoning": "tsx test/axiom-os-temporal-reasoning-test.ts",
    "test:axiom-acl": "tsx test/axiom-os-axiom-acl-test.ts",
    "test:formula-axiomizer": "tsx test/axiom-os-formula-axiomizer-test.ts",
