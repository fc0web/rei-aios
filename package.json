    "test:distributed-pipeline": "tsx test/axiom-os-distributed-axiom-pipeline-test.ts",
    "test:distribution-hub": "tsx test/axiom-os-axiom-distribution-hub-test.ts",
    "test:self-axiomizer": "tsx test/axiom-os-rei-pl-self-axiomizer-test.ts",
    "test:real": "tsx test/real-file-extraction-test.ts",
    "extract": "tsx src/cli/rei-extract.ts",
